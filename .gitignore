# NDB 単体プロジェクト用（Hub ルート .gitignore と整合）
.antigravity/
.cursor/
.gemini/
.obsidian/
.vscode/

__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.env
.env.*
*.egg-info/
.claude/settings.local.json

02_Data/raw/
02_Data/processed/
02_Data/interim/
*.csv
*.xlsx
*.parquet
*.sqlite
*.db

# Master reference CSVs (prefecture-level aggregate statistics; redistributable)
!02_Data/master/
!02_Data/master/*.csv

*.log
05_Outputs/figures/
05_Outputs/reports/

.DS_Store
Thumbs.db
desktop.ini

.git.disabled_*/
**/.git.nested_repo_backup/
.serena/
.env.temp
nul

03_Analysis/**/logs/*.log

# GitHub 単一ファイル 100MB 制限（大きいジオデータは LFS かローカルのみ）
*.geojson
*.shp
*.dbf
*.shx
*.prj

# 大容量アーカイブ・生データ（再ダウンロードで再現）
*.zip
*.7z
*.pkl

# Microsoft Word lock files
~$*.docx

# 国土数値情報など数百 MB 超（GitHub 100MB 制限）
data/raw/MLIT_N03/
**/MLIT_N03/
data/raw/**/*.xml
data/temp/**/*.xml

